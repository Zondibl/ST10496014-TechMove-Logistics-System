<!-- Views/Home/Index.cshtml -->
@{
    ViewData["Title"] = "Home Page";
}

<style>

    body {
        overflow: hidden;
    }

    .hero-section {
        background: linear-gradient(to right, #0f172a, #1e3a8a);
        color: white;
        padding: 30px 20px;
        text-align: center;
        border-radius: 10px;
        margin-bottom: 15px;
    }

        .hero-section h1 {
            font-size: 34px;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .hero-section p {
            font-size: 15px;
            margin-top: 5px;
            margin-bottom: 0;
        }

    .nav-cards {
        margin-top: 10px;
    }

    .row {
        justify-content: center;
    }

    .card {
        transition: transform 0.3s ease;
        border: none;
        box-shadow: 0 3px 8px rgba(0,0,0,0.1);
        height: 100%;
    }

        .card:hover {
            transform: scale(1.02);
        }

        .card img {
            height: 120px;
            object-fit: cover;
        }

    .card-body {
        padding: 12px;
    }

    .card-title {
        font-size: 16px;
        margin-bottom: 8px;
    }

    .card-text {
        font-size: 13px;
        margin-bottom: 10px;
        min-height: 40px;
    }

    .btn-custom {
        background-color: #1e3a8a;
        color: white;
        font-size: 13px;
        padding: 6px 12px;
    }

        .btn-custom:hover {
            background-color: #2563eb;
            color: white;
        }

    .footer-section {
        margin-top: 15px;
        text-align: center;
        padding: 10px;
        background-color: #f1f5f9;
        border-radius: 8px;
        font-size: 13px;
    }

        .footer-section h4 {
            font-size: 18px;
            margin-bottom: 5px;
        }

</style>

<div class="hero-section">
    <h1>Welcome to TechMove Logistics</h1>
    <p>
        Smart Logistics Solutions for Contracts, Service Requests,
        and Global Operations.
    </p>
</div>

<div class="container nav-cards">
    <div class="row">

        <!-- Contract Management -->
        <div class="col-md-2 mb-3">
            <div class="card">
                <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40"
                     class="card-img-top"
                     alt="Contract Management">

                <div class="card-body text-center">
                    <h5 class="card-title">Contract Management</h5>
                    <p class="card-text">
                        Manage logistics contracts and agreements efficiently.
                    </p>

                    <a asp-controller="Home"
                       asp-action="ContractManagement"
                       class="btn btn-custom">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Service Request -->
