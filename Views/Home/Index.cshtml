                     alt="Service Request">

                <div class="card-body text-center">
                    <h5 class="card-title">Service Request</h5>
                    <p class="card-text">
                        Submit and track logistics service requests online.
                    </p>

                    <a asp-controller="ServiceRequests"
                       asp-action="Index"
                       class="btn btn-custom">
                        Open
                    </a>
                </div>
            </div>
        </div>

